# ==============================================
# OpenClaw Task System 环境配置
# ==============================================
#
# 推荐使用自动配置脚本: node scripts/setup.js
# 它会自动读取 ~/.openclaw/openclaw.json 并生成此文件
#
# 手动配置请参照下方说明
# ==============================================

# --- 服务器配置 ---
PORT=8081
HOST=0.0.0.0

# --- 基础 URL ---
# 任务系统的外部访问地址，用于通知消息中的链接
e.g. https://tasks.example.com
BASE_URL=http://localhost:8081
TASK_API_URL=http://localhost:8081

# --- OpenClaw Gateway 配置 ---
# 必需！从 ~/.openclaw/openclaw.json 获取
# 找到 gateway.auth.token 字段
GATEWAY_PORT=18789
GATEWAY_TOKEN=你的_gateway_token
GATEWAY_URL=ws://127.0.0.1:18789
GATEWAY_MODE=local

# --- Agent 配置 ---
# 与 OpenClaw agents.entries 保持一致
AGENT_LIST=main,coder,deep,fast,chat,test,office
DEFAULT_MODEL=qwen-coding/qwen3.6-plus
INSTANCE_ID=

# --- JWT 认证 ---
# 必须配置！运行 openssl rand -hex 32 生成密钥
JWT_SECRET=

# --- 默认管理员账号 (首次登录使用) ---
DEFAULT_ADMIN_EMAIL=admin@taskplatform.com
DEFAULT_ADMIN_PASSWORD=admin123

# --- 飞书集成 (可选) ---
# 用于飞书消息推送、文档同步
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# --- Redis 缓存 (可选) ---
# 用于高性能场景下的缓存和队列
# REDIS_URL=redis://localhost:6379

# --- AI 模型 API Keys (可选) ---
# 根据你使用的 Provider 填写
# NVIDIA_API_KEY=
# NVIDIA_RPM=60
# NVIDIA_TPM=50000
# NVIDIA_CONCURRENT=3

# --- 部署加密 (可选) ---
# 用于 SSH 部署时的密码加密
# 部署加密密钥（必须配置）
DEPLOY_AES_SECRET=

# --- 许可证 (可选) ---
# LICENSE_KEY=
# 许可证签名密钥（必须配置）
LICENSE_SECRET=

# --- Agent IM 服务 ---
AGENT_IM_URL=http://localhost:18793
AGENT_WS_URL=ws://localhost:18793

# --- 工作目录 ---
WORKSPACE_DIR=.
